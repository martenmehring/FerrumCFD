/target/

# Local mesh input and generated OpenFOAM-like case output can be very large
# and may contain private geometry.
*.msh
*.vtk
*.vtu
*.stl
*.step
*.stp
/examples/*/constant/
/examples/*/system/

# Curated tutorial bundles are versioned below /tutorials. Generated runs and
# meshes belong below /target and remain ignored by the rule above.
